# Copie para .env: cp .env.example .env
# Gere a SECRET_KEY com: openssl rand -hex 32

SECRET_KEY=troque-esta-chave-para-producao-use-python3-secrets-token-hex-32
DATABASE_URL=sqlite:///database.db
FLASK_ENV=production
EMULATION_MODE=local

# ── Capas automáticas (configure ao menos uma) ──
# SteamGridDB — GRATUITO em https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=

# TheGamesDB — GRATUITO em https://api.thegamesdb.net
THEGAMESDB_API_KEY=

# ScreenScraper — GRATUITO em https://www.screenscraper.fr
SCREENSCRAPER_USER=
SCREENSCRAPER_PASS=
