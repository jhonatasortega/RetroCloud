SECRET_KEY=troque-esta-chave-por-uma-forte
DATABASE_URL=sqlite:///database.db
FLASK_ENV=production
EMULATION_MODE=local

# ── Scraping de capas (configure ao menos um) ──────────────────

# SteamGridDB — MAIS FÁCIL, gratuito sem review
# Crie sua key em: https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=

# IGDB (Twitch) — gratuito, precisa de conta Twitch
# Crie em: https://dev.twitch.tv/console
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# TheGamesDB — gratuito com registro
# Crie em: https://api.thegamesdb.net
THEGAMESDB_API_KEY=

# ScreenScraper — gratuito com conta
# Crie em: https://www.screenscraper.fr
SCREENSCRAPER_USER=
SCREENSCRAPER_PASS=
