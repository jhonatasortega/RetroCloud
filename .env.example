# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# OBRIGATÓRIO: gere uma chave forte com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-forte

# Banco de dados (SQLite para uso local, PostgreSQL para produção)
DATABASE_URL=sqlite:///database.db

# Emulação: "local" (browser) ou "server" (WebRTC streaming)
EMULATION_MODE=local

# TheGamesDB API Key (gratuita em https://api.thegamesdb.net)
THEGAMESDB_API_KEY=

# ScreenScraper (alternativa, gratuita em https://www.screenscraper.fr)
SCREENSCRAPER_USER=
SCREENSCRAPER_PASS=

# Modo de ambiente
FLASK_ENV=production
